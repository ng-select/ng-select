{
	"repository": "ng-select/ng-select",
	"scripts": {
		"ng": "ng",
		"build": "ng build ng-select && ng build ng-option-highlight && pnpm build:themes && pnpm copy-sass",
		"build:demo": "ng build demo --configuration production && pnpm copy-examples",
		"build:themes": "sass --style=compressed src/ng-select/themes/:dist/ng-select/themes",
		"copy-sass": "mkdir -p dist/ng-select/scss && cp src/ng-select/**/*.scss dist/ng-select/scss",
		"copy-examples": "cp -r src/demo/app/examples dist/demo/browser",
		"start": "ng serve",
		"test:watch": "ng test ng-select --watch",
		"test": "ng test ng-select --code-coverage && ng test ng-option-highlight --code-coverage",
		"test:ci": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
		"coveralls": "cat ./coverage/ng-select/lcov.info | ./node_modules/coveralls/bin/coveralls.js",
		"lint": "ng lint ng-select && ng lint ng-option-highlight",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"postpublish": "cp dist/ng-select/package.json src/ng-select && cp dist/ng-option-highlight/package.json src/ng-option-highlight",
		"release": "semantic-release",
		"postinstall": "patch-package",
		"prepare": "patch-package"
	},
	"release": {
		"branch": "master",
		"plugins": [
			"@semantic-release/commit-analyzer",
			"@semantic-release/changelog",
			"@semantic-release/github",
			[
				"@semantic-release/npm",
				{
					"pkgRoot": "dist/ng-select"
				}
			],
			"@semantic-release/release-notes-generator"
		]
	},
	"dependencies": {
		"@angular/animations": "^22.0.4",
		"@angular/cdk": "22.0.2",
		"@angular/common": "^22.0.4",
		"@angular/compiler": "^22.0.4",
		"@angular/core": "^22.0.4",
		"@angular/forms": "^22.0.4",
		"@angular/localize": "^22.0.4",
		"@angular/material": "22.0.2",
		"@angular/platform-browser": "^22.0.4",
		"@angular/platform-browser-dynamic": "^22.0.4",
		"@angular/router": "^22.0.4",
		"@angular/ssr": "^22.0.4",
		"@ng-bootstrap/ng-bootstrap": "21.0.0",
		"@popperjs/core": "2.11.8",
		"bootstrap": "^5.3.8",
		"rxjs": "^7.8.2",
		"tslib": "^2.8.1",
		"zone.js": "~0.16.2"
	},
	"devDependencies": {
		"@angular/build": "^22.0.4",
		"@angular/cli": "^22.0.4",
		"@angular/compiler-cli": "^22.0.4",
		"@angular/language-service": "^22.0.4",
		"@eslint/js": "^10.0.1",
		"@semantic-release/changelog": "^6.0.3",
		"@stackblitz/sdk": "^1.11.0",
		"@types/node": "^26.0.1",
		"@vitest/coverage-v8": "^4.1.9",
		"angular-eslint": "22.0.0",
		"baseline-browser-mapping": "^2.10.40",
		"coveralls": "^3.1.1",
		"eslint": "10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsdoc": "63.0.9",
		"eslint-plugin-prefer-arrow": "^1.2.3",
		"istanbul-lib-instrument": "^6.0.3",
		"jsdom": "^29.1.1",
		"ng-packagr": "^22.0.0",
		"node-gyp": "^13.0.0",
		"patch-package": "^8.0.1",
		"prettier": "^3.8.5",
		"sass": "^1.101.0",
		"semantic-release": "^25.0.5",
		"standard-version": "^9.5.0",
		"ts-node": "~10.9.2",
		"typescript": "~6.0.3",
		"typescript-eslint": "8.62.0",
		"vitest": "^4.1.9"
	}
}
