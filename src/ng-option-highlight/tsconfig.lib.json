{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"outDir": "../../out-tsc/lib",
		"declaration": true,
		"inlineSources": true,
		"types": [
			"node"
		],
		"lib": [
			"ES2022",
			"dom",
			"esnext"
		]
	},
	"angularCompilerOptions": {
		"compilationMode": "partial",
		"extendedDiagnostics": {
			"checks": {
				"nullishCoalescingNotNullable": "suppress",
				"optionalChainNotNullable": "suppress"
			}
		},
		"strictInjectionParameters": true,
		"strictTemplates": false
	},
	"exclude": [
		"**/*.spec.ts"
	]
}
