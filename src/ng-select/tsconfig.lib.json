{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"outDir": "../../out-tsc/lib",
		"declaration": true,
		"inlineSources": true,
		"strict": false,
		"strictNullChecks": false,
		"strictPropertyInitialization": false,
		"noImplicitAny": false,
		"types": [
			"node"
		],
		"lib": [
			"ES2022",
			"dom",
			"esnext"
		]
	},
	"exclude": [
		"**/*.spec.ts"
	]
}
